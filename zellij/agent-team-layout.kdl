layout {
    pane split_direction="vertical" {
        pane size="65%" command="claude" {
            focus true
        }
        pane size="35%" command="bash" {
            // .heyyou/ の作業ディレクトリを用意し、共有ファイルを眺めるための watcher ペイン
            args "-lc" "mkdir -p .heyyou/design .heyyou/reviews .heyyou/discussions && yazi .heyyou"
        }
    }
}
